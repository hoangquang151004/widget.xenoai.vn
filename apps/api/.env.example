# ============================================================
# XenoAI Widget — Backend API Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Tách môi trường (mẫu):
#   Development: .env.development.example
#   Production:  .env.production.example

# ── General ─────────────────────────────────────────────────
ENV=development                # development | production
DEBUG=true

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=widget_chatbot

# Full URL (optional — overrides individual settings above)
# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:password@localhost:5432/widget_chatbot

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Qdrant Vector DB ─────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                          # Leave empty for local/no-auth
QDRANT_COLLECTION_DOCS=chatbot_documents

# ── Google Gemini AI ─────────────────────────────────────────
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIM=3072

# ── Security ─────────────────────────────────────────────────
# REQUIRED: 32-byte base64 key for AES-256-GCM encryption of tenant DB credentials
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
APP_ENCRYPTION_KEY=your_32_byte_base64_key_here

# General app secret key (for internal use, not the API keys)
SECRET_KEY=change_me_in_production_please

# ── RAG Settings ─────────────────────────────────────────────
RAG_MAX_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.7

# ── CORS ─────────────────────────────────────────────────────
# Tenant-level origin check is in middleware; this is fallback
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Sentry (optional) ────────────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── PayOS (thanh toán — tùy chọn) ─────────────────────────────
# PAYOS_CLIENT_ID=
# PAYOS_API_KEY=
# PAYOS_CHECKSUM_KEY=
# PAYOS_CHECKOUT_RETURN_URL=http://localhost:3000/dashboard/billing?payos=success
# PAYOS_CHECKOUT_CANCEL_URL=http://localhost:3000/dashboard/billing?payos=cancel
# PAYOS_AMOUNT_PRO_VND=500000
# PAYOS_AMOUNT_ENTERPRISE_VND=2000000
# PAYOS_AMOUNT_ENTERPRISE_PRO_VND=5000000
