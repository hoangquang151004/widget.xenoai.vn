# ============================================================
# XenoAI Widget — Next.js Frontend Environment Variables
# ============================================================
# Copy to .env.local:
#   cp .env.example .env.local
#
# Mẫu thêm: .env.development.example | .env.production.example

# URL của Backend API (không có trailing slash)
# Development: http://localhost:8001
# Docker:      http://api:8001
# Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8001

# Email hiển thị trên trang Hỗ trợ (mailto). Tùy chọn.
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourcompany.com

# Email ưu tiên cho CTA gói / báo giá trên trang Billing (fallback: SUPPORT_EMAIL).
# NEXT_PUBLIC_SALES_EMAIL=sales@yourcompany.com
