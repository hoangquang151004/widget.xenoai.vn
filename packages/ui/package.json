{
  "name": "@widget-chatbot/ui",
  "version": "0.1.0",
  "description": "Shared React components for chatbot widget",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.13.0 <25",
    "npm": ">=11.6.2 <12"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.emit.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.2",
    "vitest": "^3.0.0"
  }
}